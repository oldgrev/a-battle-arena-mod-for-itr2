        if (outResolvedActor) *outResolvedActor = resolvedName;
        return true;
    }

    int StopAllMedia()
    {
        std::lock_guard<std::mutex> lock(gMediaMutex);
        int stopped = 0;
        for (const ActiveMediaInstance& instance : gActiveMedia)
        {
            if (instance.Player && SDK::UKismetSystemLibrary::IsValid(instance.Player))
            {
                instance.Player->Close();
                ++stopped;
            }

            if (instance.SoundComponent && SDK::UKismetSystemLibrary::IsValid(instance.SoundComponent))
            {
                instance.SoundComponent->Deactivate();
                instance.SoundComponent->K2_DestroyComponent(instance.SoundComponent);
            }
        }
        gActiveMedia.clear();
        return stopped;
    }

    std::string DescribeActiveMedia(std::size_t maxEntries)
    {
        std::lock_guard<std::mutex> lock(gMediaMutex);
        std::ostringstream oss;
        oss << "Active media: " << gActiveMedia.size();

        std::size_t shown = 0;
        for (const ActiveMediaInstance& instance : gActiveMedia)
        {
            if (shown++ >= maxEntries)
            {
                oss << "\n  ...";
                break;
            }

            const bool validPlayer = (instance.Player && SDK::UKismetSystemLibrary::IsValid(instance.Player));
            oss << "\n  [" << shown << "] "
                << (instance.IsAttached3D ? "3D" : "2D")
                << " " << (validPlayer ? "playing" : "invalid")
                << " :: " << instance.Descriptor;
        }

        return oss.str();
    }

    bool ScanSoundGroupsFromFolder(const std::string& folderPath, std::string* outError)
    {
        if (folderPath.empty())
        {
            if (outError) *outError = "folder path is empty";
            return false;
        }

        std::error_code ec;
        const std::filesystem::path root(folderPath);
        if (!std::filesystem::exists(root, ec) || !std::filesystem::is_directory(root, ec))
        {
            if (outError) *outError = "folder not found or not a directory";
            return false;
        }

        // discovered accumulates entries from both audio files and .txt files.
        // Groups are cumulative: spotted-man1.wav + spotted.txt both end up in group 'spotted'.
        std::unordered_map<std::string, std::vector<std::string>> discovered;
        int txtFilesRead = 0;
        int txtEntriesAdded = 0;

        std::filesystem::recursive_directory_iterator it(root, std::filesystem::directory_options::skip_permission_denied, ec);
        std::filesystem::recursive_directory_iterator endIt;
        for (; it != endIt; it.increment(ec))
        {
            if (ec) { ec.clear(); continue; }
            if (!it->is_regular_file(ec) || ec) { ec.clear(); continue; }

            const std::filesystem::path fp = it->path();
            const std::string extLower = ToLowerCopy(fp.extension().string());

            if (extLower == ".txt")
            {
                // Each non-empty, non-comment line is a file path or URL.
                // The group name comes from the .txt file's stem (same DeriveGroupName logic).
                const std::string group = DeriveGroupName(fp);
                std::ifstream tf(fp);
                if (!tf.is_open()) continue;
                std::string line;
                int lineAdded = 0;
                while (std::getline(tf, line))
                {
                    line = TrimWhitespace(line);
                    if (line.empty() || line[0] == '#') continue;
                    discovered[group].push_back(line);
                    ++lineAdded;
                    ++txtEntriesAdded;
                }
                ++txtFilesRead;
                LOG_INFO("[ModFeedback] ScanSounds: parsed '" << fp.filename().string() << "' -> group '" << group << "' (" << lineAdded << " entries)");
            }
            else if (IsSupportedAudioExtension(fp))
            {
                const std::string group = DeriveGroupName(fp);
                discovered[group].push_back(fp.string());
            }
        }

        // Sort each group's entries for determinism.
        for (auto& entry : discovered)
        {
            std::sort(entry.second.begin(), entry.second.end());
        }

        int newGroups = 0;
        int newEntries = 0;
        {
            std::lock_guard<std::mutex> lock(gSoundGroupMutex);
            // Merge cumulatively into existing gSoundGroups so calling scan twice
            // (or scanning multiple folders) accumulates rather than replaces entries.
            for (auto& kv : discovered)
            {
                auto& target = gSoundGroups[kv.first];
                const bool wasEmpty = target.empty();
                for (const auto& e : kv.second)
                {
                    if (std::find(target.begin(), target.end(), e) == target.end())
                    {
                        target.push_back(e);
                        ++newEntries;
                    }
                }
                if (wasEmpty && !target.empty()) ++newGroups;
            }
            gSoundGroupsSourceFolder = root.string();
        }

        LOG_INFO("[ModFeedback] Sound groups scanned from '" << root.string()
            << "' (discovered_groups=" << discovered.size()
            << ", txt_files=" << txtFilesRead
            << ", txt_entries=" << txtEntriesAdded
            << ", new_groups=" << newGroups
            << ", new_entries=" << newEntries << ")");
        return true;
    }

    std::string DescribeSoundGroups(std::size_t maxGroups, std::size_t maxEntriesPerGroup)
    {
        std::vector<std::pair<std::string, std::vector<std::string>>> groups;
        std::string source;
        {
            std::lock_guard<std::mutex> lock(gSoundGroupMutex);
            source = gSoundGroupsSourceFolder;
            groups.reserve(gSoundGroups.size());
            for (const auto& kv : gSoundGroups)
            {
                groups.push_back(kv);
            }
        }

        std::sort(groups.begin(), groups.end(), [](const auto& a, const auto& b)
        {
            return a.first < b.first;
        });

        std::ostringstream oss;
        oss << "Sound groups: " << groups.size();
        if (!source.empty())
            oss << " (source: " << source << ")";

        std::size_t shownGroups = 0;
        for (const auto& kv : groups)
        {
            if (shownGroups++ >= maxGroups)
            {
                oss << "\n  ...";
                break;
            }

            oss << "\n  " << kv.first << " (" << kv.second.size() << "): ";
            for (std::size_t i = 0; i < kv.second.size() && i < maxEntriesPerGroup; ++i)
            {
                if (i > 0)
                    oss << ", ";
                oss << std::filesystem::path(kv.second[i]).filename().string();
            }

            if (kv.second.size() > maxEntriesPerGroup)
                oss << ", ...";
        }

        return oss.str();
    }

    bool PlayRandomSoundGroup2D(const std::string& groupName, bool loop, float volume, std::string* outChosenFile, std::string* outError)
    {
        const std::string groupKey = ToLowerCopy(groupName);
        if (groupKey.empty())
        {
            if (outError) *outError = "group name is empty";
            return false;
        }

        // Copy the group entries under lock so we can iterate without holding the lock during playback.
        std::vector<std::string> entries;
        {
            std::lock_guard<std::mutex> lock(gSoundGroupMutex);
            const auto it = gSoundGroups.find(groupKey);
            if (it == gSoundGroups.end() || it->second.empty())
            {
                if (outError) *outError = "group not found or empty";
                return false;
            }
            entries = it->second;
        }

        // Shuffle to get random order for retry.
        std::shuffle(entries.begin(), entries.end(), gSoundGroupRng);

        const int maxRetries = (std::min)(Mod::Tuning::kSoundGroupRetryCount, (int)entries.size());
        std::string lastErr;
        for (int attempt = 0; attempt < maxRetries; ++attempt)
        {
            const std::string& entry = entries[attempt];
            std::string err;
            // Discern URL vs file path for correct playback method.
            const bool ok = IsUrl(entry)
                ? PlayMediaUrl2D(entry, loop, volume, &err)
                : PlayMediaFile2D(entry, loop, volume, &err);

            if (ok)
            {
                if (outChosenFile) *outChosenFile = entry;
                LOG_INFO("[ModFeedback] PlayRandomSoundGroup2D ok (group='" << groupKey
                    << "', entry='" << entry << "', attempt=" << attempt + 1 << ")");
                return true;
            }

            lastErr = err;
            LOG_WARN("[ModFeedback] PlayRandomSoundGroup2D attempt " << attempt + 1
                << " failed (group='" << groupKey << "', entry='" << entry << "'): " << err);
        }

        if (outError) *outError = "all " + std::to_string(maxRetries) + " attempts failed; last: " + lastErr;
        LOG_ERROR("[ModFeedback] PlayRandomSoundGroup2D exhausted retries (group='" << groupKey << "')");
        return false;
    }

    // ---------------------------------------------------------------------------
    // Actor-attached media helpers (actor pointer variants, no string selector)
    // ---------------------------------------------------------------------------

    bool PlayMediaFileAttachedToActor(SDK::AActor* actor, const std::string& filePath, bool loop, float volume, std::string* outError)
    {
        LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor begin (actor=" << actor
            << ", file='" << filePath << "', loop=" << (loop ? 1 : 0)
            << ", volumeReq=" << volume << ")");
        if (!actor)
        {
            if (outError) *outError = "actor is null";
            LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor result=failure reason='actor is null'");
            return false;
        }
        std::string err;
        SDK::UMediaPlayer* player = SpawnMediaPlayer(&err);
        if (!player)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor result=failure stage='SpawnMediaPlayer' error='" << err << "'");
            return false;
        }

        SDK::UMediaSoundComponent* mediaSound = SpawnAttachedMediaSoundComponent(actor, &err);
        if (!mediaSound)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor result=failure stage='SpawnAttachedMediaSoundComponent' error='" << err << "'");
            return false;
        }

        mediaSound->SetMediaPlayer(player);
        const float requestedVolume = volume;
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;
        LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor open-attempt type=file volumeReq=" << requestedVolume
            << " volumeClamped=" << volume << " target='" << filePath << "'");

        const bool opened = player->OpenFile(SDK::FString(ToWide(filePath).c_str()));
        LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor open result opened=" << (opened ? 1 : 0));
        if (!PlayMediaCommonOpenResult(player, opened, loop, volume, std::string("file3d@actor: ") + filePath, outError))
        {
            LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor result=failure stage='PlayMediaCommonOpenResult' opened=" << (opened ? 1 : 0)
                << " target='" << filePath << "'");
            return false;
        }
        LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor open succeeded for '" << filePath << "'");

        RegisterActiveMedia(player, mediaSound, actor, std::string("3d file@actor: ") + filePath, true);
        LOG_INFO("[ModFeedback] PlayMediaFileAttachedToActor result=success player=" << player
            << " mediaSound=" << mediaSound << " target='" << filePath << "'");
        return true;
    }

    bool PlayMediaUrlAttachedToActor(SDK::AActor* actor, const std::string& url, bool loop, float volume, std::string* outError)
    {
        LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor begin (actor=" << actor
            << ", url='" << url << "', loop=" << (loop ? 1 : 0)
            << ", volumeReq=" << volume << ")");
        if (!actor)
        {
            if (outError) *outError = "actor is null";
            LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor result=failure reason='actor is null'");
            return false;
        }
        std::string err;
        SDK::UMediaPlayer* player = SpawnMediaPlayer(&err);
        if (!player)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor result=failure stage='SpawnMediaPlayer' error='" << err << "'");
            return false;
        }
//MetaSoundSource A_MS_Assault_Rifle_Movement_Rattle.A_MS_Assault_Rifle_Movement_Rattle
        SDK::UMediaSoundComponent* mediaSound = SpawnAttachedMediaSoundComponent(actor, &err);
        if (!mediaSound)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor result=failure stage='SpawnAttachedMediaSoundComponent' error='" << err << "'");
            return false;
        }

        mediaSound->SetMediaPlayer(player);
        const float requestedVolume = volume;
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;
        LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor open-attempt type=url volumeReq=" << requestedVolume
            << " volumeClamped=" << volume << " target='" << url << "'");

        const bool opened = player->OpenUrl(SDK::FString(ToWide(url).c_str()));
        if (!PlayMediaCommonOpenResult(player, opened, loop, volume, std::string("url3d@actor: ") + url, outError))
        {
            LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor result=failure stage='PlayMediaCommonOpenResult' opened=" << (opened ? 1 : 0)
                << " target='" << url << "'");
            return false;
        }
        LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor open succeeded for '" << url << "'");

        RegisterActiveMedia(player, mediaSound, actor, std::string("3d url@actor: ") + url, true);
        LOG_INFO("[ModFeedback] PlayMediaUrlAttachedToActor result=success player=" << player
            << " mediaSound=" << mediaSound << " target='" << url << "'");
        return true;
    }

    // =========================================================================
    // SynthSamplePlayer-based 3D spatial audio (the proper UE5 path)
    // USynthSamplePlayer inherits from USynthComponent which has built-in 3D
    // spatialization support. This avoids the raw-PCM-to-USoundWave issues.
    // =========================================================================
    static bool PlayWavAttachedToActorViaSynth(SDK::AActor* actor, const std::string& filePath, bool loop, float volume, std::string* outError)
    {
        LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth begin (actor=" << actor
            << ", file='" << filePath << "', loop=" << (loop ? 1 : 0)
            << ", volumeReq=" << volume << ")");
        if (!actor)
        {
            if (outError) *outError = "actor is null";
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth result=failure reason='actor is null'");
            return false;
        }

        // Parse the WAV file
        std::string err;
        ParsedWav wav;
        if (!ParseWavFile(filePath, wav, &err))
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth result=failure stage='ParseWavFile' error='" << err << "'");
            LOG_ERROR("[ModFeedback] PlayWavViaSynth ParseWavFile failed: " << err);
            return false;
        }

        // Create a USoundWave for the synth player
        SDK::USoundWave* sw = LoadWavAsSoundWave(wav, loop, nullptr, &err);
        if (!sw)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth result=failure stage='LoadWavAsSoundWave' error='" << err << "'");
            LOG_ERROR("[ModFeedback] PlayWavViaSynth LoadWavAsSoundWave failed: " << err);
            return false;
        }

        // Spawn USynthSamplePlayer attached to the actor
        SDK::USynthSamplePlayer* synthPlayer = SpawnAttachedSynthSamplePlayer(actor, &err);
        if (!synthPlayer)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth result=failure stage='SpawnAttachedSynthSamplePlayer' error='" << err << "'");
            LOG_ERROR("[ModFeedback] PlayWavViaSynth SpawnAttachedSynthSamplePlayer failed: " << err);
            return false;
        }

        LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth spawn succeeded for actor '" << actor->GetName() << "'");

        // Configure the synth player with the sound wave
        synthPlayer->SetSoundWave(sw);

        // Configure volume via SetVolumeMultiplier
        const float requestedVolume = volume;
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;
        LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth play-attempt volumeReq=" << requestedVolume
            << " volumeClamped=" << volume << " file='" << filePath << "'");
        synthPlayer->SetVolumeMultiplier(volume);

        // Start playback
        synthPlayer->Start();

        // Retrieve the heap buffer we put into sw so we can free it after playback
        uint8_t* pcmBuf = *reinterpret_cast<uint8_t**>(reinterpret_cast<uint8_t*>(sw) + kSoundWaveRawPCMDataOffset);
        const uint64_t startTickMs = NowTickMs();
        const float durationSec = (wav.numChannels > 0 && wav.sampleRate > 0)
            ? static_cast<float>(wav.pcmData.size()) / static_cast<float>(wav.numChannels * 2u * wav.sampleRate)
            : 0.0f;
        const uint32_t durationMs = durationSec > 0.0f ? static_cast<uint32_t>(durationSec * 1000.0f) : 0u;

        // Track the instance for cleanup
        {
            std::lock_guard<std::mutex> lock(gSynthMutex);
            ActiveSynthInstance inst;
            inst.SynthPlayer = synthPlayer;
            inst.OwnerActor = actor;
            inst.PcmBuffer = pcmBuf;
            inst.Descriptor = "synth:" + filePath;
            inst.StartTickMs = startTickMs;
            inst.ExpectedDurationMs = durationMs;
            inst.Looping = loop;
            inst.DiagStage = 0;
            gActiveSynth.push_back(inst);
            LogSynthInstanceSnapshot("spawn-registered", gActiveSynth.back(), 0, "post-register");
        }

        LOG_INFO("[ModFeedback] PlayWavViaSynth ok ('" << filePath << "', loop=" << loop
            << ", vol=" << volume << ", ch=" << wav.numChannels
            << ", sr=" << wav.sampleRate << ", pcmBytes=" << wav.pcmData.size()
            << ", durationMs~" << durationMs << ")");
        LOG_INFO("[ModFeedback] PlayWavAttachedToActorViaSynth result=success synthPlayer=" << synthPlayer
            << " soundWave=" << sw << " file='" << filePath << "'");

        return true;
    }

    // Play a .wav file attached to a moving actor for true 3D spatial audio.
    // Uses native UE5 UAudioComponent (not WMF) so the spatial pipeline actually runs.
    // Steps:
    //   1. Parse WAV and build USoundWave with raw PCM (ForceInline, ESoundAssetCompressionType::PCM)
    //   2. AddComponentByClass(UAudioComponent) – unregistered, no vtable dance yet
    //   3. Write 3D flags directly (bAllowSpatialization=1, bOverrideAttenuation=1, bIsUISound=0)
    //      and set AttenuationOverrides before ANY engine-side voice creation
    //   4. Attach to actor root
    //   5. SetSound(sw)  ← no hardware voice yet
    //   6. Play(0.0f)    ← hardware voice created HERE with our 3D settings already baked in
    // Falls through to media (WMF, audible but 2D) only if step 1 or 2 fails.
    bool PlayWavAttachedToActorDirect(SDK::AActor* actor, const std::string& filePath, bool loop, float volume, std::string* outError)
    {
        std::string err;
        ParsedWav wav;
        if (!ParseWavFile(filePath, wav, &err))
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect result=failure stage='ParseWavFile' error='" << err << "'");
            return false;
        }

        SDK::USoundWave* sw = LoadWavAsSoundWave(wav, loop, nullptr, &err);
        if (!sw)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect result=failure stage='LoadWavAsSoundWave' error='" << err << "'");
            return false;
        }

        SDK::USceneComponent* root = actor->K2_GetRootComponent();
        if (!root)
        {
            if (outError) *outError = "actor has no root component";
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect result=failure stage='K2_GetRootComponent'");
            return false;
        }

        // Create UAudioComponent on the actor with bManualAttachment=true so we can
        // configure it before the engine does anything with it.
        SDK::UObject* added = actor->AddComponentByClass(
            SDK::UAudioComponent::StaticClass(), true, SDK::FTransform{}, false);
        if (!added || !added->IsA(SDK::UAudioComponent::StaticClass()))
        {
            if (outError) *outError = "AddComponentByClass(UAudioComponent) failed";
            LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect result=failure stage='AddComponentByClass(UAudioComponent)'");
            return false;
        }
        SDK::UAudioComponent* audComp = static_cast<SDK::UAudioComponent*>(added);

        // ── Configure 3D flags BEFORE SetSound / Play ────────────────────────
        // The hardware audio voice is not created until Play() is called.
        // Setting flags here means Play() bakes them in at voice creation time.
        audComp->bAllowSpatialization = true;
        audComp->bIsUISound           = false;
        audComp->bOverrideAttenuation = true;
        audComp->bAutoDestroy         = true;  // engine cleans up after playback ends
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;
        audComp->VolumeMultiplier     = volume;

        {
            auto& aa = audComp->AttenuationOverrides;
            aa.bAttenuate            = true;
            aa.bSpatialize           = true;
            aa.DistanceAlgorithm     = SDK::EAttenuationDistanceModel::Linear;
            aa.AttenuationShape      = SDK::EAttenuationShape::Sphere;
            aa.FalloffDistance       = 2000.0f;
            aa.dBAttenuationAtMax    = -60.0f;
            aa.bAttenuateWithLPF     = true;
            aa.LPFRadiusMin          = 100.0f;
            aa.LPFRadiusMax          = 2000.0f;
            aa.LPFFrequencyAtMin     = 20000.0f;
            aa.LPFFrequencyAtMax     = 500.0f;
        }

        // Attach to actor root, then wire up the sound and start playback.
        const bool attached = audComp->K2_AttachToComponent(
            root,
            SDK::FName{},
            SDK::EAttachmentRule::SnapToTarget,
            SDK::EAttachmentRule::SnapToTarget,
            SDK::EAttachmentRule::SnapToTarget,
            false);
        LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect attach=" << (attached ? 1 : 0));

        audComp->SetSound(sw);
        audComp->Play(0.0f);

        const bool playing = SDK::UKismetSystemLibrary::IsValid(audComp) && audComp->IsPlaying();
        const SDK::EAudioComponentPlayState ps = SDK::UKismetSystemLibrary::IsValid(audComp)
            ? audComp->GetPlayState()
            : SDK::EAudioComponentPlayState::Stopped;

        LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect post-play"
            << " actor='" << actor->GetName() << "'"
            << " file='" << filePath << "'"
            << " playing=" << (playing ? 1 : 0)
            << " playState=" << static_cast<int>(ps)
            << " swCh=" << sw->NumChannels
            << " swSr=" << *reinterpret_cast<const int32_t*>(reinterpret_cast<const uint8_t*>(sw) + kSoundWaveSampleRateOffset)
            << " swPcmBytes=" << *reinterpret_cast<const uint32_t*>(reinterpret_cast<const uint8_t*>(sw) + kSoundWaveRawPCMDataSizeOffset)
            << " loop=" << (loop ? 1 : 0)
            << " volume=" << volume);

        if (ps == SDK::EAudioComponentPlayState::Stopped)
        {
            if (outError) *outError = "UAudioComponent stopped immediately after Play()";
            LOG_WARN("[ModFeedback] PlayWavAttachedToActorDirect: UAudioComponent stopped immediately — USoundWave PCM may not be usable by engine decompressor");
            return false;
        }

        // Track for cleanup
        uint8_t* pcmBuf = *reinterpret_cast<uint8_t**>(reinterpret_cast<uint8_t*>(sw) + kSoundWaveRawPCMDataOffset);
        const float durationSec = (wav.numChannels > 0 && wav.sampleRate > 0)
            ? static_cast<float>(wav.pcmData.size()) / static_cast<float>(wav.numChannels * 2u * wav.sampleRate)
            : 0.0f;
        const uint32_t durationMs = durationSec > 0.0f ? static_cast<uint32_t>(durationSec * 1000.0f) : 0u;
        const uint64_t startTickMs = NowTickMs();

        {
            std::lock_guard<std::mutex> lock(gWavMutex);
            gActiveWav.push_back({audComp, actor, pcmBuf,
                std::string("direct:") + filePath, startTickMs, durationMs, loop, 0});
        }

        LOG_INFO("[ModFeedback] PlayWavAttachedToActorDirect result=success file='" << filePath << "' durationMs=" << durationMs);
        return true;
    }

    // Play a .wav file attached to a moving actor for true 3D spatial audio.
    // Tries multiple paths in order of robustness:
    // 1. Direct UAudioComponent + USoundWave (native UE5 pipeline, true 3D)
    // 2. UMediaPlayer + UMediaSoundComponent (audible but WMF = 2D, fallback only)
    // 3. USynthSamplePlayer
    // 4. Raw PCM SpawnSoundAttached (legacy diagnostic path)
    bool PlayWavAttachedToActor(SDK::AActor* actor, const std::string& filePath, bool loop, float volume, std::string* outError)
    {
        LOG_INFO("[ModFeedback] PlayWavAttachedToActor begin (actor=" << actor
            << ", file='" << filePath << "', loop=" << (loop ? 1 : 0)
            << ", volumeReq=" << volume << ")");
        if (!actor)
        {
            if (outError) *outError = "actor is null";
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=failure reason='actor is null'");
            return false;
        }

        // Primary path: native UAudioComponent + USoundWave (goes through UE5 spatial pipeline).
        // UMediaSoundComponent (WMF) is intentionally NOT tried first — WMF bypasses UE's
        // spatial audio renderer and always produces 2D output regardless of bAllowSpatialization.
        std::string directErr;
        if (PlayWavAttachedToActorDirect(actor, filePath, loop, volume, &directErr))
        {
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=success path='direct' file='" << filePath << "'");
            return true;
        }
        LOG_WARN("[ModFeedback] PlayWavAttachedToActor: direct path failed (" << directErr
            << "), falling back to media (WMF, 2D) for file='" << filePath << "'");

        // Fallback: WMF media — audible but 2D. Better than silence while we fix the direct path.
        std::string mediaErr;
        if (PlayMediaFileAttachedToActor(actor, filePath, loop, volume, &mediaErr))
        {
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=success path='media-fallback' file='" << filePath << "'");
            return true;
        }
        LOG_INFO("[ModFeedback] PlayWavAttachedToActor path='media-fallback' result=failure error='" << mediaErr
            << "' file='" << filePath << "'");
        LOG_WARN("[ModFeedback] PlayWavAttachedToActor: media path failed, falling back to synth path ('"
            << filePath << "'): " << mediaErr);

        // Secondary path: USynthSamplePlayer (raw-PCM USoundWave often fails silently)
        std::string synthErr;
        if (PlayWavAttachedToActorViaSynth(actor, filePath, loop, volume, &synthErr))
        {
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor: synth path ok ('" << filePath
                << "', loop=" << (loop ? 1 : 0) << ", volume=" << volume << ")");
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=success path='synth' file='" << filePath << "'");
            return true;
        }
        LOG_INFO("[ModFeedback] PlayWavAttachedToActor path='synth' result=failure error='" << synthErr
            << "' file='" << filePath << "'");
        LOG_WARN("[ModFeedback] PlayWavAttachedToActor: synth path failed, falling back to raw-PCM path ('"
            << filePath << "'): " << synthErr);

        std::string err;
        ParsedWav wav;
        if (!ParseWavFile(filePath, wav, &err))
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=failure stage='ParseWavFile(raw-pcm-path)' error='" << err << "'");
            LOG_ERROR("[ModFeedback] PlayWavAttachedToActor ParseWavFile failed: " << err);
            return false;
        }

        SDK::USoundWave* sw = LoadWavAsSoundWave(wav, loop, nullptr, &err);
        if (!sw)
        {
            if (outError) *outError = err;
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=failure stage='LoadWavAsSoundWave(raw-pcm-path)' error='" << err << "'");
            LOG_ERROR("[ModFeedback] PlayWavAttachedToActor LoadWavAsSoundWave failed: " << err);
            return false;
        }

        SDK::USoundAttenuation* att = CreateSpatialAttenuation3D();
        // att may be null; SpawnSoundAttached accepts null attenuation (falls back to asset attenuation)

        const float requestedVolume = volume;
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;
        LOG_INFO("[ModFeedback] PlayWavAttachedToActor raw-pcm-path volumeReq=" << requestedVolume
            << " volumeClamped=" << volume << " file='" << filePath << "'");

        SDK::USceneComponent* root = actor->K2_GetRootComponent();
        if (!root)
        {
            if (outError) *outError = "actor has no root component";
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=failure stage='K2_GetRootComponent' error='actor has no root component'");
            return false;
        }

        SDK::UAudioComponent* audComp = SDK::UGameplayStatics::SpawnSoundAttached(
            sw,
            root,
            SDK::FName{},
            SDK::FVector{0.0f, 0.0f, 0.0f},
            SDK::FRotator{0.0f, 0.0f, 0.0f},
            SDK::EAttachLocation::KeepRelativeOffset,
            false,   // bStopWhenAttachedToDestroyed
            volume,
            1.0f,    // pitch
            0.0f,    // start time
            att,
            nullptr, // no concurrency
            false    // managed by CleanupStaleWav; avoid premature engine auto-destroy
        );

        if (!audComp)
        {
            if (outError) *outError = "SpawnSoundAttached returned null";
            LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=failure stage='SpawnSoundAttached(raw-pcm-path)' file='" << filePath << "'");
            LOG_ERROR("[ModFeedback] PlayWavAttachedToActor SpawnSoundAttached failed for: " << filePath);
            return false;
        }

        const bool validBeforePlay = SDK::UKismetSystemLibrary::IsValid(audComp);
        const bool playingBeforePlay = validBeforePlay ? audComp->IsPlaying() : false;
        const SDK::EAudioComponentPlayState playStateBeforePlay = validBeforePlay
            ? audComp->GetPlayState()
            : SDK::EAudioComponentPlayState::Stopped;

        // Defensive: explicitly start playback in case the component was created but not auto-playing yet.
        audComp->Play(0.0f);

        const bool validAfterPlay = SDK::UKismetSystemLibrary::IsValid(audComp);
        const bool playingAfterPlay = validAfterPlay ? audComp->IsPlaying() : false;
        const SDK::EAudioComponentPlayState playStateAfterPlay = validAfterPlay
            ? audComp->GetPlayState()
            : SDK::EAudioComponentPlayState::Stopped;

        // Retrieve the heap buffer we put into sw so we can free it after playback
        uint8_t* pcmBuf = *reinterpret_cast<uint8_t**>(reinterpret_cast<uint8_t*>(sw) + kSoundWaveRawPCMDataOffset);
        const uint64_t startTickMs = NowTickMs();
        const float durationSec = (wav.numChannels > 0 && wav.sampleRate > 0)
            ? static_cast<float>(wav.pcmData.size()) / static_cast<float>(wav.numChannels * 2u * wav.sampleRate)
            : 0.0f;
        const uint32_t durationMs = durationSec > 0.0f ? static_cast<uint32_t>(durationSec * 1000.0f) : 0u;

        const int32_t swSampleRate = *reinterpret_cast<int32_t*>(reinterpret_cast<uint8_t*>(sw) + kSoundWaveSampleRateOffset);
        const float swDuration = *reinterpret_cast<float*>(reinterpret_cast<uint8_t*>(sw) + kSoundBaseDurationOffset);
        const float swTotalSamples = *reinterpret_cast<float*>(reinterpret_cast<uint8_t*>(sw) + kSoundBaseTotalSamplesOffset);
        const uint32_t swRawPcmSize = *reinterpret_cast<uint32_t*>(reinterpret_cast<uint8_t*>(sw) + kSoundWaveRawPCMDataSizeOffset);
        const uint64_t parsedHash = HashBytesFnv1a64(wav.pcmData.data(), wav.pcmData.size());
        const uint64_t heapHash = HashBytesFnv1a64(pcmBuf, swRawPcmSize);
        const bool pcmMirror = pcmBuf
            && swRawPcmSize == wav.pcmData.size()
            && std::memcmp(pcmBuf, wav.pcmData.data(), swRawPcmSize) == 0;
        const SDK::ESoundAssetCompressionType swCompression = sw->GetSoundAssetCompressionType();

        LOG_INFO("[ModFeedback] WAV_DIAG phase=spawn-soundwave"
            << " entry='" << filePath << "'"
            << " swPtr=" << sw
            << " swValid=" << (IsValidObject(sw) ? 1 : 0)
            << " swNumChannels=" << sw->NumChannels
            << " swLooping=" << (sw->bLooping ? 1 : 0)
            << " swStreaming=" << (sw->bStreaming ? 1 : 0)
            << " swSampleRate=" << swSampleRate
            << " swDuration=" << swDuration
            << " swTotalSamples=" << swTotalSamples
            << " swRawPcmPtr=" << static_cast<const void*>(pcmBuf)
            << " swRawPcmSize=" << swRawPcmSize
            << " swRawPcmHash=" << heapHash
            << " parsedPcmBytes=" << wav.pcmData.size()
            << " parsedPcmHash=" << parsedHash
            << " pcmMirror=" << (pcmMirror ? 1 : 0)
            << " parsedDurationMs=" << durationMs
            << " swLoadingBehavior=" << static_cast<int>(sw->LoadingBehavior)
            << "(" << SoundWaveLoadingBehaviorName(sw->LoadingBehavior) << ")"
            << " swCompression=" << static_cast<int>(swCompression)
            << "(" << SoundAssetCompressionName(swCompression) << ")"
            << " actorPtr=" << actor
            << " actorValid=" << (IsValidObject(actor) ? 1 : 0)
            << " rootPtr=" << root
            << " rootValid=" << (IsValidObject(root) ? 1 : 0)
            << " attenuationPtr=" << att
            << " attenuationValid=" << (IsValidObject(att) ? 1 : 0)
            << " volumeArg=" << volume
            << " loopArg=" << (loop ? 1 : 0) << ")");

        LogSoundWaveObject("spawn-generated", filePath.c_str(), sw);

        {
            std::lock_guard<std::mutex> lock(gWavMutex);
            gActiveWav.push_back({audComp, actor, pcmBuf, filePath, startTickMs, durationMs, loop, 0});
            LogWavInstanceSnapshot("spawn-registered", gActiveWav.back(), 0, "post-register");
        }

        LOG_INFO("[ModFeedback] PlayWavAttachedToActor ok (" << filePath << ", loop=" << loop
            << ", vol=" << volume << ", ch=" << wav.numChannels
            << ", sr=" << wav.sampleRate << ", pcmBytes=" << wav.pcmData.size()
            << ", durationMs~" << durationMs
            << ", stateBeforePlay={valid=" << (validBeforePlay ? 1 : 0)
            << ", playing=" << (playingBeforePlay ? 1 : 0)
            << ", playState=" << static_cast<int>(playStateBeforePlay)
            << "(" << AudioPlayStateName(playStateBeforePlay) << ")"
            << "}, stateAfterPlay={valid=" << (validAfterPlay ? 1 : 0)
            << ", playing=" << (playingAfterPlay ? 1 : 0)
            << ", playState=" << static_cast<int>(playStateAfterPlay)
            << "(" << AudioPlayStateName(playStateAfterPlay) << ")"
            << "})");
        LOG_INFO("[ModFeedback] PlayWavAttachedToActor result=success path='raw-pcm' file='" << filePath << "'");
        return true;
    }

    bool PlayWavAttachedToPlayerWithTemplate(const std::string& templateSoftObjectPath, const std::string& filePath, bool loop, float volume, std::string* outError)
    {
        SDK::ABP_RadiusPlayerCharacter_Gameplay_C* player = Mod::GameContext::GetPlayerCharacter();
        if (!player)
        {
            if (outError) *outError = "no local player character";
            return false;
        }

        if (templateSoftObjectPath.empty())
        {
            if (outError) *outError = "template soft object path is empty";
            return false;
        }

        std::string err;
        ParsedWav wav;
        if (!ParseWavFile(filePath, wav, &err))
        {
            if (outError) *outError = err;
            LOG_ERROR("[ModFeedback] PlayWavAttachedToPlayerWithTemplate ParseWavFile failed: " << err);
            return false;
        }

        SDK::USoundBase* templateSound = LoadSoundAssetBySoftPath(templateSoftObjectPath, &err);
        if (!templateSound)
        {
            if (outError) *outError = err;
            LOG_ERROR("[ModFeedback] PlayWavAttachedToPlayerWithTemplate template load failed: " << err);
            return false;
        }
        if (!templateSound->IsA(SDK::USoundWave::StaticClass()))
        {
            if (outError) *outError = "template is not a USoundWave: " + templateSound->GetFullName();
            return false;
        }

        SDK::USoundWave* templateWave = static_cast<SDK::USoundWave*>(templateSound);
        LogSoundWaveObject("template-source", templateSoftObjectPath.c_str(), templateWave);

        SDK::USoundWave* generated = LoadWavAsSoundWave(wav, loop, templateWave, &err);
        if (!generated)
        {
            if (outError) *outError = err;
            return false;
        }
        LogSoundWaveObject("template-generated", filePath.c_str(), generated);

        SDK::USceneComponent* root = player->K2_GetRootComponent();
        if (!root)
        {
            if (outError) *outError = "player has no root component";
            return false;
        }

        SDK::USoundAttenuation* att = CreateSpatialAttenuation3D();
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;

        SDK::UAudioComponent* audComp = SDK::UGameplayStatics::SpawnSoundAttached(
            generated,
            root,
            SDK::FName{},
            SDK::FVector{0.0f, 0.0f, 0.0f},
            SDK::FRotator{0.0f, 0.0f, 0.0f},
            SDK::EAttachLocation::KeepRelativeOffset,
            false,
            volume,
            1.0f,
            0.0f,
            att,
            nullptr,
            false);

        if (!audComp)
        {
            if (outError) *outError = "SpawnSoundAttached returned null";
            return false;
        }

        audComp->Play(0.0f);

        uint8_t* pcmBuf = *reinterpret_cast<uint8_t**>(reinterpret_cast<uint8_t*>(generated) + kSoundWaveRawPCMDataOffset);
        const uint32_t swRawPcmSize = *reinterpret_cast<uint32_t*>(reinterpret_cast<uint8_t*>(generated) + kSoundWaveRawPCMDataSizeOffset);
        const uint64_t startTickMs = NowTickMs();
        const float durationSec = (wav.numChannels > 0 && wav.sampleRate > 0)
            ? static_cast<float>(wav.pcmData.size()) / static_cast<float>(wav.numChannels * 2u * wav.sampleRate)
            : 0.0f;
        const uint32_t durationMs = durationSec > 0.0f ? static_cast<uint32_t>(durationSec * 1000.0f) : 0u;

        {
            std::lock_guard<std::mutex> lock(gWavMutex);
            gActiveWav.push_back(ActiveWavInstance{
                audComp,
                player,
                pcmBuf,
                std::string("template:") + templateSoftObjectPath + " -> " + filePath,
                startTickMs,
                durationMs,
                loop,
                0
            });

            LogWavInstanceSnapshot("spawn-registered-template", gActiveWav.back(), 0, "post-register-template");
        }

        const uint64_t parsedHash = HashBytesFnv1a64(wav.pcmData.data(), wav.pcmData.size());
        const uint64_t heapHash = HashBytesFnv1a64(pcmBuf, swRawPcmSize);
        LOG_INFO("[ModFeedback] PlayWavAttachedToPlayerWithTemplate ok (template='" << templateSoftObjectPath
            << "', wav='" << filePath
            << "', parsedPcmBytes=" << wav.pcmData.size()
            << ", swRawPcmSize=" << swRawPcmSize
            << ", parsedHash=" << parsedHash
            << ", swHash=" << heapHash
            << ", loop=" << (loop ? 1 : 0)
            << ", volume=" << volume << ")");

        return true;
    }

    std::string DescribeLoadedSoundWaves(std::size_t maxEntries, const std::string& containsFilter, bool includeDefaultObjects)
    {
        const std::string filterLower = ToLowerCopy(containsFilter);
        const std::vector<SDK::USoundWave*> found = FindLoadedSoundWaves(filterLower, includeDefaultObjects);

        std::ostringstream oss;
        oss << "Loaded soundwaves: " << found.size();
        if (!containsFilter.empty())
            oss << " (filter='" << containsFilter << "')";

        const std::size_t show = (std::min)(maxEntries, found.size());
        for (std::size_t i = 0; i < show; ++i)
        {
            SDK::USoundWave* sw = found[i];
            if (!sw)
                continue;

            const SDK::ESoundAssetCompressionType compression = sw->GetSoundAssetCompressionType();
            oss << "\n  [" << (i + 1) << "] "
                << sw->GetFullName()
                << " ch=" << sw->NumChannels
                << " sr=" << sw->SampleRate
                << " stream=" << (sw->bStreaming ? 1 : 0)
                << " load=" << static_cast<int>(sw->LoadingBehavior)
                << "(" << SoundWaveLoadingBehaviorName(sw->LoadingBehavior) << ")"
                << " comp=" << static_cast<int>(compression)
                << "(" << SoundAssetCompressionName(compression) << ")";

            LogSoundWaveObject("discover", sw->GetFullName().c_str(), sw);
        }

        if (found.size() > show)
            oss << "\n  ...";

        return oss.str();
    }

    bool PlayWavAttachedToPlayerAutoTemplate(const std::string& filePath, bool loop, float volume, const std::string& containsFilter, std::string* outTemplateName, std::string* outError)
    {
        const std::string filterLower = ToLowerCopy(containsFilter);
        const std::vector<SDK::USoundWave*> found = FindLoadedSoundWaves(filterLower, false);
        if (found.empty())
        {
            if (outError)
                *outError = containsFilter.empty()
                    ? "no loaded non-default USoundWave objects found"
                    : "no loaded non-default USoundWave objects matched filter '" + containsFilter + "'";
            return false;
        }

        SDK::USoundWave* picked = ChooseAutoTemplateSoundWave(found);
        if (!picked)
        {
            if (outError) *outError = "failed to pick an auto template soundwave";
            return false;
        }

        const std::string pickedName = picked->GetFullName();
        if (outTemplateName)
            *outTemplateName = pickedName;

        LogSoundWaveObject("auto-template-picked", pickedName.c_str(), picked);

        SDK::ABP_RadiusPlayerCharacter_Gameplay_C* player = Mod::GameContext::GetPlayerCharacter();
        if (!player)
        {
            if (outError) *outError = "no local player character";
            return false;
        }

        std::string err;
        ParsedWav wav;
        if (!ParseWavFile(filePath, wav, &err))
        {
            if (outError) *outError = err;
            return false;
        }

        SDK::USoundWave* generated = LoadWavAsSoundWave(wav, loop, picked, &err);
        if (!generated)
        {
            if (outError) *outError = err;
            return false;
        }
        LogSoundWaveObject("auto-template-generated", filePath.c_str(), generated);

        SDK::USceneComponent* root = player->K2_GetRootComponent();
        if (!root)
        {
            if (outError) *outError = "player has no root component";
            return false;
        }

        SDK::USoundAttenuation* att = CreateSpatialAttenuation3D();
        if (volume < 0.0f) volume = 0.0f;
        if (volume > 4.0f) volume = 4.0f;

        SDK::UAudioComponent* audComp = SDK::UGameplayStatics::SpawnSoundAttached(
            generated,
            root,
            SDK::FName{},
            SDK::FVector{0.0f, 0.0f, 0.0f},
            SDK::FRotator{0.0f, 0.0f, 0.0f},
            SDK::EAttachLocation::KeepRelativeOffset,
            false,
            volume,
            1.0f,
            0.0f,
            att,
            nullptr,
            false);

        if (!audComp)
        {
            if (outError) *outError = "SpawnSoundAttached returned null";
            return false;
        }

        audComp->Play(0.0f);

        uint8_t* pcmBuf = *reinterpret_cast<uint8_t**>(reinterpret_cast<uint8_t*>(generated) + kSoundWaveRawPCMDataOffset);
        const uint32_t swRawPcmSize = *reinterpret_cast<uint32_t*>(reinterpret_cast<uint8_t*>(generated) + kSoundWaveRawPCMDataSizeOffset);
        const uint64_t startTickMs = NowTickMs();
        const float durationSec = (wav.numChannels > 0 && wav.sampleRate > 0)
            ? static_cast<float>(wav.pcmData.size()) / static_cast<float>(wav.numChannels * 2u * wav.sampleRate)
            : 0.0f;
        const uint32_t durationMs = durationSec > 0.0f ? static_cast<uint32_t>(durationSec * 1000.0f) : 0u;

        {
            std::lock_guard<std::mutex> lock(gWavMutex);
            gActiveWav.push_back(ActiveWavInstance{
                audComp,
                player,
                pcmBuf,
                std::string("auto-template:") + pickedName + " -> " + filePath,
                startTickMs,
                durationMs,
                loop,
                0
            });
            LogWavInstanceSnapshot("spawn-registered-auto-template", gActiveWav.back(), 0, "post-register-auto-template");
        }

        const uint64_t parsedHash = HashBytesFnv1a64(wav.pcmData.data(), wav.pcmData.size());
        const uint64_t heapHash = HashBytesFnv1a64(pcmBuf, swRawPcmSize);
        LOG_INFO("[ModFeedback] PlayWavAttachedToPlayerAutoTemplate ok (picked='" << pickedName
            << "', wav='" << filePath
            << "', parsedPcmBytes=" << wav.pcmData.size()
            << ", swRawPcmSize=" << swRawPcmSize
            << ", parsedHash=" << parsedHash
            << ", swHash=" << heapHash
            << ", loop=" << (loop ? 1 : 0)
            << ", volume=" << volume << ")");

        return true;
    }

    bool IsMediaPlayingForActor(SDK::AActor* actor)
    {
        if (!actor) return false;
        {
            std::lock_guard<std::mutex> lock(gMediaMutex);
            for (const auto& inst : gActiveMedia)
            {
                if (inst.OwnerActor != actor) continue;
                if (inst.Player && SDK::UKismetSystemLibrary::IsValid(inst.Player) && inst.Player->IsPlaying())
                    return true;
            }
        }
        {
            std::lock_guard<std::mutex> lock(gWavMutex);
            for (const auto& inst : gActiveWav)
            {
                if (inst.OwnerActor != actor) continue;
                if (inst.AudioComp && SDK::UKismetSystemLibrary::IsValid(inst.AudioComp))
                {
                    const SDK::EAudioComponentPlayState playState = inst.AudioComp->GetPlayState();
                    if (IsAudioPlayStateActive(playState))
                        return true;

                    // Treat just-started audio as active to avoid immediate re-triggers while it initializes.
                    const uint64_t nowMs = NowTickMs();
                    const uint64_t ageMs = (nowMs >= inst.StartTickMs) ? (nowMs - inst.StartTickMs) : 0;
                    const uint64_t graceMs = static_cast<uint64_t>(Mod::Tuning::kWavStaleCleanupDelaySeconds * 1000.0f);
                    uint64_t minKeepAliveMs = graceMs;
                    if (!inst.Looping && inst.ExpectedDurationMs > 0)
                    {
                        const uint64_t completionSlackMs = static_cast<uint64_t>(Mod::Tuning::kWavPlaybackCompletionSlackSeconds * 1000.0f);
                        const uint64_t expectedDoneMs = static_cast<uint64_t>(inst.ExpectedDurationMs) + completionSlackMs;
                        if (expectedDoneMs > minKeepAliveMs)
                            minKeepAliveMs = expectedDoneMs;
                    }
                    if (ageMs < minKeepAliveMs)
                        return true;
                }
            }
        }
        return false;
    }

    int StopMediaForActor(SDK::AActor* actor)
    {
        if (!actor) return 0;
        int stopped = 0;
        {
            std::lock_guard<std::mutex> lock(gMediaMutex);
            gActiveMedia.erase(std::remove_if(gActiveMedia.begin(), gActiveMedia.end(),
                [actor, &stopped](const ActiveMediaInstance& inst)
                {
                    if (inst.OwnerActor != actor) return false;
                    if (inst.Player && SDK::UKismetSystemLibrary::IsValid(inst.Player))
                    {
                        inst.Player->Close();
                        ++stopped;
                    }
                    if (inst.SoundComponent && SDK::UKismetSystemLibrary::IsValid(inst.SoundComponent))
                    {
                        inst.SoundComponent->Deactivate();
                        inst.SoundComponent->K2_DestroyComponent(inst.SoundComponent);
                    }
                    return true;
                }
            ), gActiveMedia.end());
        }
        {
            std::lock_guard<std::mutex> lock(gWavMutex);
            gActiveWav.erase(std::remove_if(gActiveWav.begin(), gActiveWav.end(),
                [actor, &stopped](ActiveWavInstance& inst)
                {
                    if (inst.OwnerActor != actor) return false;
                    if (inst.AudioComp && SDK::UKismetSystemLibrary::IsValid(inst.AudioComp))
                    {
                        inst.AudioComp->Stop();
                        inst.AudioComp->K2_DestroyComponent(inst.AudioComp);
                        ++stopped;
                    }
                    delete[] inst.PcmBuffer;
                    inst.PcmBuffer = nullptr;
                    return true;
                }
            ), gActiveWav.end());
        }
        return stopped;
    }

    bool PlayRandomSoundGroupAttachedToActor(SDK::AActor* actor, const std::string& groupName, bool loop, float volume, std::string* outChosenEntry, std::string* outError)
    {
        LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor begin (actor=" << actor
            << ", group='" << groupName << "', loop=" << (loop ? 1 : 0)
            << ", volume=" << volume << ")");
        if (!actor)
        {
            if (outError) *outError = "actor is null";
            LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor result=failure reason='actor is null'");
            return false;
        }

        const std::string groupKey = ToLowerCopy(groupName);
        if (groupKey.empty())
        {
            if (outError) *outError = "group name is empty";
            LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor result=failure reason='group name is empty'");
            return false;
        }

        std::vector<std::string> entries;
        {
            std::lock_guard<std::mutex> lock(gSoundGroupMutex);
            const auto it = gSoundGroups.find(groupKey);
            if (it == gSoundGroups.end() || it->second.empty())
            {
                if (outError) *outError = std::string("group '") + groupKey + "' not found or empty";
                LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor result=failure reason='group not found or empty' group='" << groupKey << "'");
                return false;
            }
            entries = it->second;
        }

        std::shuffle(entries.begin(), entries.end(), gSoundGroupRng);

        const int maxRetries = (std::min)(Mod::Tuning::kSoundGroupRetryCount, (int)entries.size());
        LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor prepared (group='" << groupKey
            << "', entries=" << entries.size() << ", maxRetries=" << maxRetries << ")");
        std::string lastErr;
        for (int attempt = 0; attempt < maxRetries; ++attempt)
        {
            const std::string& entry = entries[attempt];
            std::string err;
            // .wav files use SpawnSoundAttached for true 3D spatial audio;
            // URLs and other file types fall through to the UMediaPlayer path.
            const bool isWav = !IsUrl(entry) && entry.size() >= 4
                && (entry.compare(entry.size() - 4, 4, ".wav") == 0
                 || entry.compare(entry.size() - 4, 4, ".WAV") == 0);
            const bool isUrlEntry = IsUrl(entry);
            const char* dispatch = isWav ? "wav" : (isUrlEntry ? "url" : "file");
            LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor dispatch (group='" << groupKey
                << "', attempt=" << attempt + 1 << "/" << maxRetries
                << ", entry='" << entry << "', dispatch='" << dispatch << "')");
            const bool ok = isWav
                ? PlayWavAttachedToActor(actor, entry, loop, volume, &err)
                : (isUrlEntry
                    ? PlayMediaUrlAttachedToActor(actor, entry, loop, volume, &err)
                    : PlayMediaFileAttachedToActor(actor, entry, loop, volume, &err));

            if (ok)
            {
                if (outChosenEntry) *outChosenEntry = entry;
                LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor dispatch-result=success (group='" << groupKey
                    << "', attempt=" << attempt + 1 << ", dispatch='" << dispatch
                    << "', entry='" << entry << "')");
                LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor ok (group='" << groupKey
                    << "', entry='" << entry << "', attempt=" << attempt + 1 << ")");
                return true;
            }

            lastErr = err;
            LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor dispatch-result=failure (group='" << groupKey
                << "', attempt=" << attempt + 1 << ", dispatch='" << dispatch
                << "', entry='" << entry << "', error='" << err << "')");
            LOG_WARN("[ModFeedback] PlayRandomSoundGroupAttachedToActor attempt " << attempt + 1
                << " failed (group='" << groupKey << "', entry='" << entry << "'): " << err);
        }

        if (outError) *outError = "all " + std::to_string(maxRetries) + " attempts failed; last: " + lastErr;
        LOG_INFO("[ModFeedback] PlayRandomSoundGroupAttachedToActor result=failure exhausted (group='" << groupKey
            << "', maxRetries=" << maxRetries << ", lastError='" << lastErr << "')");
        LOG_ERROR("[ModFeedback] PlayRandomSoundGroupAttachedToActor exhausted retries (group='" << groupKey << "')");
        return false;
    }

    void InitSoundSystem()
    {
        const std::filesystem::path soundsFolder = std::filesystem::current_path() / Mod::Tuning::kDefaultSoundsFolder;
        std::error_code ec;
        const bool exists = std::filesystem::exists(soundsFolder, ec) && std::filesystem::is_directory(soundsFolder, ec);
        if (exists)
        {
            LOG_INFO("[ModFeedback] Default sounds folder found: " << soundsFolder.string() << " -- scanning...");
            std::string err;
            if (!ScanSoundGroupsFromFolder(soundsFolder.string(), &err))
            {
                LOG_WARN("[ModFeedback] Sounds folder scan failed: " << err);
            }
        }
        else
        {
            LOG_INFO("[ModFeedback] Default sounds folder NOT found at: " << soundsFolder.string()
                << " (create 'sounds/' next to the DLL to enable sound groups)");
        }
    }
}
